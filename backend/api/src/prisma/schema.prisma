model Aluno {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  telefone  String?
  createdAt DateTime @default(now())

  treinos   Treino[]
}

model Professor {
  id            Int      @id @default(autoincrement())
  nome          String
  email         String   @unique
  especialidade String?
  createdAt     DateTime @default(now())

  treinos       Treino[]
}

model Equipamento {
  id        Int       @id @default(autoincrement())
  nome      String
  tipo      String?
  descricao String?

  exercicios Exercicio[]
}

model Exercicio {
  id            Int          @id @default(autoincrement())
  nome          String
  grupoMuscular String?
  descricao     String?

   equipamentos  Equipamento[]
  treinoExercicios TreinoExercicio[]
}

model Treino {
  id          Int      @id @default(autoincrement())
  nome        String
  objetivo    String?
  dataCriacao DateTime @default(now())

  alunoId     Int
  aluno       Aluno    @relation(fields: [alunoId], references: [id])

  professorId Int
  professor   Professor @relation(fields: [professorId], references: [id])

  exercicios  TreinoExercicio[]
}

model TreinoExercicio {
  id          Int @id @default(autoincrement())

  treinoId    Int
  treino      Treino @relation(fields: [treinoId], references: [id])

  exercicioId Int
  exercicio   Exercicio @relation(fields: [exercicioId], references: [id])

  series      Int?
  repeticoes  Int?
  carga       Float?
  descanso    Int?
  observacoes String?
  ordem       Int?

  @@unique([treinoId, exercicioId])
}
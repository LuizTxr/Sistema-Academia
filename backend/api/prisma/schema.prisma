generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Aluno {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  createdAt DateTime @default(now())
}

model Professor {
  id    Int    @id @default(autoincrement())
  nome  String
  email String @unique

  treinos Treino[]
}

model Equipamento {
  id        Int     @id @default(autoincrement())
  nome      String
  tipo      String?
  descricao String?

  exercicios ExercicioEquipamento[]
}

model Exercicio {
  id            Int     @id @default(autoincrement())
  nome          String
  grupoMuscular String?

  equipamentos ExercicioEquipamento[]
  treinos      TreinoExercicio[]
}

model ExercicioEquipamento {
  exercicioId   Int
  equipamentoId Int

  exercicio   Exercicio   @relation(fields: [exercicioId], references: [id])
  equipamento Equipamento @relation(fields: [equipamentoId], references: [id])

  @@id([exercicioId, equipamentoId])
}

model Treino {
  id          Int    @id @default(autoincrement())
  nome        String
  descricao   String?

  professorId Int
  professor   Professor @relation(fields: [professorId], references: [id])

  exercicios TreinoExercicio[]
}

model TreinoExercicio {
  treinoId    Int
  exercicioId Int

  series      Int?
  repeticoes  Int?
  carga       Float?

  treino    Treino    @relation(fields: [treinoId], references: [id])
  exercicio Exercicio @relation(fields: [exercicioId], references: [id])

  @@id([treinoId, exercicioId])
}